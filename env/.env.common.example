# Shared non-secret values for all environments.
# Copy to env/.env.common.
# Secrets (API keys, passwords, tokens) belong in env/.env.secrets instead.
#
# Loader order (when split files exist):
#   env/.env.secrets -> env/.env.common -> env/.env.<profile> -> env/.env.<profile>.<service>
# profile: MINSY_ENV_PROFILE (dev/prod)
# service: MINSY_SERVICE (api|mcp|worker_cpu|worker_io|beat)
# Override options:
#   MINSY_ENV_FILES=/abs/a.env,/abs/b.env
#   MINSY_ENV_FILE=/abs/single.env

# ── App Identity ─────────────────────────────────
APP_NAME=Minsy
API_V1_PREFIX=/api/v1

# ── OpenAI (non-secret) ─────────────────────────
OPENAI_RESPONSE_MODEL=gpt-5.2
OPENAI_COST_TRACKING_ENABLED=true

# ── Stripe Billing (non-secret defaults) ───────
# Leave URLs empty to use backend-hosted fallback page:
#   {API_PUBLIC_BASE_URL}/api/v1/billing/return?billing=success|cancel|portal
# Optional frontend base URL used to build one-click return target:
#   {BILLING_FRONTEND_BASE_URL}/settings?billing=success|cancel|portal
# If empty, backend will try request Origin/Referer automatically.
BILLING_FRONTEND_BASE_URL=
BILLING_CHECKOUT_SUCCESS_URL=
BILLING_CHECKOUT_CANCEL_URL=
BILLING_PORTAL_RETURN_URL=
# Unified billing/pricing config (preferred):
# {
#   "openai_pricing": {"gpt-5.2": {"input_per_1k_tokens": 0.00175, "output_per_1k_tokens": 0.014}},
#   "cost_model": {"token_cost_per_1k_usd": 0.01, "ai_usage_unit_usd": 0.00001, "cpu_bars_per_token": 52560, "target_profit_margin": 0.5, "plus_price_usd": 20, "pro_price_usd": 60},
#   "tier_limits": {"free": {"ai_tokens_monthly_total": 100000, "cpu_tokens_monthly_total": 20, "strategies_current_count": 5, "deployments_running_count": 1}, "plus": {"ai_tokens_monthly_total": 1000000, "cpu_tokens_monthly_total": 200, "strategies_current_count": 30, "deployments_running_count": 5}, "pro": {"ai_tokens_monthly_total": 3000000, "cpu_tokens_monthly_total": 600, "strategies_current_count": 100, "deployments_running_count": 20}}
# }
BILLING_PRICING_JSON={"openai_pricing":{"gpt-5.2":{"input_per_1k_tokens":0.00175,"output_per_1k_tokens":0.014}},"cost_model":{"token_cost_per_1k_usd":0.01,"ai_usage_unit_usd":0.00001,"cpu_bars_per_token":52560,"target_profit_margin":0.5,"plus_price_usd":20,"pro_price_usd":60},"tier_limits":{"free":{"ai_tokens_monthly_total":100000,"cpu_tokens_monthly_total":20,"strategies_current_count":5,"deployments_running_count":1},"plus":{"ai_tokens_monthly_total":1000000,"cpu_tokens_monthly_total":200,"strategies_current_count":30,"deployments_running_count":5},"pro":{"ai_tokens_monthly_total":3000000,"cpu_tokens_monthly_total":600,"strategies_current_count":100,"deployments_running_count":20}}}

# ── MCP Context (non-secret) ────────────────────
MCP_CONTEXT_TTL_SECONDS=300

# ── Telegram (non-secret toggles) ───────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_AUTO_SYNC_ENABLED=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_CONNECT_TTL_SECONDS=600
