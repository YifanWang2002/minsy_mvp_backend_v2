# Shared non-secret values for all environments.
# Copy to env/.env.common.
# Secrets (API keys, passwords, tokens) belong in env/.env.secrets instead.
#
# Loader order (when split files exist):
#   env/.env.secrets -> env/.env.common -> env/.env.<profile> -> env/.env.<profile>.<service>
# profile: MINSY_ENV_PROFILE (dev/prod)
# service: MINSY_SERVICE (api|mcp|worker_cpu|worker_io|beat)
# Override options:
#   MINSY_ENV_FILES=/abs/a.env,/abs/b.env
#   MINSY_ENV_FILE=/abs/single.env

# ── App Identity ─────────────────────────────────
APP_NAME=Minsy
API_V1_PREFIX=/api/v1

# ── OpenAI (non-secret) ─────────────────────────
OPENAI_RESPONSE_MODEL=gpt-5.2
OPENAI_ALLOWED_MODELS_JSON=["gpt-5.2","gpt-5.4"]
OPENAI_CHAIN_RESET_TURNS_PER_PHASE=8
OPENAI_PROMPT_INPUT_MAX_CHARS=32000
OPENAI_COST_TRACKING_ENABLED=true

# ── Stripe Billing (non-secret defaults) ───────
# Leave URLs empty to use backend-hosted fallback page:
#   {API_PUBLIC_BASE_URL}/api/v1/billing/return?billing=success|cancel|portal
# Optional frontend base URL used to build one-click return target:
#   {BILLING_FRONTEND_BASE_URL}/settings?billing=success|cancel|portal
# If empty, backend will try request Origin/Referer automatically.
BILLING_FRONTEND_BASE_URL=
BILLING_CHECKOUT_SUCCESS_URL=
BILLING_CHECKOUT_CANCEL_URL=
BILLING_PORTAL_RETURN_URL=
