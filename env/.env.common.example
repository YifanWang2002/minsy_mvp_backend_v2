# ── MCP Context (non-secret) ────────────────────
MCP_CONTEXT_TTL_SECONDS=300

# ── Pre-Strategy Regime Probe ───────────────────
PRE_STRATEGY_REGIME_LOOKBACK_BARS=500
PRE_STRATEGY_REGIME_MIN_BARS=150
PRE_STRATEGY_REGIME_CACHE_TTL_SECONDS=600
PRE_STRATEGY_REGIME_PIVOT_WINDOW=5
PRE_STRATEGY_REGIME_IMAGE_MAX_BARS=240

# ── Trading WS Transport (non-secret) ───────────
TRADING_WS_PUBSUB_WAIT_SECONDS=1.0
TRADING_WS_FALLBACK_POLL_SECONDS=0.5
TRADING_WS_RECONCILE_SECONDS=2.0
TRADING_WS_PUBSUB_PROBE_BASE_SECONDS=1.0
TRADING_WS_PUBSUB_PROBE_MAX_SECONDS=15.0

# ── Telegram (non-secret toggles) ───────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_AUTO_SYNC_ENABLED=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_CONNECT_TTL_SECONDS=600
