# Celery beat scheduler overrides
# Service key: beat

CELERY_TIMEZONE=UTC

# Toggle periodic schedules at scheduler side.
POSTGRES_BACKUP_ENABLED=true
USER_EMAIL_CSV_EXPORT_ENABLED=true
BACKTEST_STALE_JOB_CLEANUP_ENABLED=true
PAPER_TRADING_ENABLED=true
NOTIFICATIONS_ENABLED=true
TRADING_APPROVAL_ENABLED=true

# Local collector schedule gate
MARKET_DATA_INCREMENTAL_EXECUTION_MODE=local_collector
MARKET_DATA_INCREMENTAL_SYNC_ENABLED=true
MARKET_DATA_INCREMENTAL_SYNC_CRON_HOUR=4
MARKET_DATA_INCREMENTAL_SYNC_CRON_MINUTE=30
